{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false,
    "rewriteRelativeImportExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleResolution": "node16",
    "module": "node16",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "index.ts"],
  "exclude": ["test", "node_modules", "dist"]
}
